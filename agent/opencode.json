{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "port": 2442,
    "hostname": "0.0.0.0"
  },
  "autoupdate": false,
  "autoshare": true,
  "permission": {
    "*": "allow",
    "lsp": "deny",
    "question": "deny"
  },
  "enabled_providers": ["openai", "google", "anthropic"],
  "default_agent": "build",
  "model": "{env:OPENCODE_MODEL}",
  "small_model": "{env:OPENCODE_SMALL_MODEL}",
  "mcp": {
    "firecrawl": {
      "type": "remote",
      "url": "https://mcp.firecrawl.dev/{env:FIRECRAWL_API_KEY}/v2/mcp"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "permission": "allow",
      "prompt": "你是 Agili, 一个反应迅速、轻盈灵巧、随需而至的 AI 精灵。你不仅擅长编程，更擅长写作和编辑。"
    },

    "editor": {
      "mode": "subagent",
      "permission": "allow",
      "model": "{env:EDITOR_MODEL}"
    },
    "researcher": {
      "mode": "subagent",
      "permission": "allow"
    },
    "reviewer": {
      "mode": "subagent",
      "permission": "allow",
      "model": "{env:REVIEW_MODEL}"
    },
    "writer": {
      "mode": "subagent",
      "permission": "allow",
      "model": "{env:WRITER_MODEL}"
    }
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}"
      }
    },
    "google": {
      "npm": "@ai-sdk/google",
      "options": {
        "baseURL": "{env:GOOGLE_BASE_URL}",
        "apiKey": "{env:GOOGLE_API_KEY}"
      }
    },
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "{env:ANTHROPIC_BASE_URL}",
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    }
  }
}
