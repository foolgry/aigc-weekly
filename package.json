{
  "name": "aigc-weekly",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": "^22"
  },
  "scripts": {
    "clean": "rimraf .next && rimraf .open-next",
    "dev:worker": "wrangler dev --port 2442 --cwd worker --persist-to ../.wrangler/state",
    "deploy:worker": "wrangler deploy --cwd worker",
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "pnpm run deploy:database && pnpm run deploy:app",
    "deploy:database": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && wrangler d1 execute D1 --command 'PRAGMA optimize' --remote",
    "deploy:app": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "pnpm run generate:types:cloudflare && pnpm run generate:types:payload",
    "generate:types:cloudflare": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts && wrangler types --cwd worker --env-interface CloudflareEnv cloudflare-env.d.ts",
    "generate:types:payload": "payload generate:types",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit && pnpm typecheck:worker",
    "typecheck:worker": "tsc -p worker/tsconfig.json --noEmit",
    "prepare": "simple-git-hooks",
    "payload": "payload",
    "wrangler": "wrangler"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@cloudflare/containers": "^0.3.3",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@next/eslint-plugin-next": "^16.2.5",
    "@opennextjs/cloudflare": "^1.19.8",
    "@payloadcms/db-d1-sqlite": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-r2": "^3.84.1",
    "@payloadcms/translations": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "@types/node": "22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/rss": "^0.0.32",
    "baseline-browser-mapping": "^2.10.27",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "graphql": "^16.14.0",
    "lint-staged": "^17.0.2",
    "markdown-it-ts": "0.0.2-beta.7",
    "next": "^15.5.18",
    "overtype": "^2.3.10",
    "payload": "^3.84.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rimraf": "^6.1.3",
    "rss": "^1.2.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "cloudflare": {
    "bindings": {
      "PAYLOAD_SECRET": {
        "description": "Generate a random string using `openssl rand -hex 32`"
      }
    }
  }
}
